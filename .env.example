# Personal Expense Tracker environment template
# Copy to the relevant app-level .env files or configure the same keys in Vercel/Render.
# Never commit real secrets.

# Shared
NODE_ENV=development
APP_TIMEZONE=Asia/Kolkata
DEFAULT_CURRENCY=INR

# MongoDB Atlas
# Setup: create a free MongoDB Atlas cluster, database user, and IP/network access rule.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/personal_expense_tracker?retryWrites=true&w=majority
DEFAULT_USER_ID=<seeded-user-object-id>

# Next.js web app
NEXT_PUBLIC_API_BASE_URL=http://localhost:10000

# Express API
PORT=10000
CLIENT_URL=http://localhost:3000
JWT_SECRET=<generate-a-long-random-secret>
SYNC_INDEXES_ON_BOOT=false

# SMS/notification webhook
# Setup: generate a secret on the laptop, configure WEBHOOK_SECRET on the phone automation app,
# then configure only WEBHOOK_SECRET_HASH in Vercel/runtime validation.
WEBHOOK_SECRET=<plaintext-secret-for-local-testing-only>
# Generate with: node -e "console.log(require('crypto').createHash('sha256').update(process.argv[1]).digest('hex'))" "your-secret"
WEBHOOK_SECRET_HASH=<sha256-hex-hash-of-webhook-secret>

# Optional future services
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
