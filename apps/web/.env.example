# SpendSense Web environment template
# Copy this file to apps/web/.env.local for local development.

NODE_ENV=development

# Web -> API
NEXT_PUBLIC_API_BASE_URL=http://localhost:10000
NEXT_PUBLIC_APP_TIMEZONE=Asia/Kolkata
NEXT_PUBLIC_DEFAULT_CURRENCY=INR
# Render cold-start resilience (bounded retries on transient errors for idempotent reads)
NEXT_PUBLIC_API_TIMEOUT_MS=10000
NEXT_PUBLIC_API_RETRY_COUNT=2
NEXT_PUBLIC_API_RETRY_BASE_DELAY_MS=400

# Shared app settings (used only if web server-side code needs them)
APP_TIMEZONE=Asia/Kolkata
DEFAULT_CURRENCY=INR

# Needed in phases where Next.js route handlers access MongoDB directly (e.g. webhook ingestion)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/personal_expense_tracker?retryWrites=true&w=majority
DEFAULT_USER_ID=<seeded-user-object-id>

# Webhook validation for Next.js route handlers
# Generate with: node -e "console.log(require('crypto').createHash('sha256').update(process.argv[1]).digest('hex'))" "your-secret"
WEBHOOK_SECRET_HASH=<sha256-hex-hash-of-webhook-secret>
WEBHOOK_SECRET=<plaintext-secret-for-local-testing-only>
