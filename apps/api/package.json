{
  "name": "@spendsense/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "node --test --test-concurrency=1 dist/transactions.test.js dist/analytics.test.js dist/statement-imports.test.js dist/settings.test.js",
    "seed:default-user": "node --import tsx src/scripts/seed-default-user.ts",
    "db:sync-indexes": "node --import tsx src/scripts/sync-indexes.ts"
  },
  "dependencies": {
    "@spendsense/shared": "0.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^2.0.2",
    "mongoose": "^8.5.3",
    "papaparse": "^5.5.3",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/papaparse": "^5.3.16",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.16.2"
  }
}
