# SpendSense API environment template
# Copy this file to apps/api/.env for local development.

NODE_ENV=development
PORT=10000
CLIENT_URL=http://localhost:3000

# Shared app settings
APP_TIMEZONE=Asia/Kolkata
DEFAULT_CURRENCY=INR

# MongoDB
MONGODB_URI=mongodb+srv://shan123:ishan123@speedsense.rppobn9.mongodb.net/
DEFAULT_USER_ID=<seeded-user-object-id>

# Auth
JWT_SECRET=<generate-a-long-random-secret>
SYNC_INDEXES_ON_BOOT=false

# Optional for phases where API validates webhooks directly
WEBHOOK_SECRET=<plaintext-secret-for-local-testing-only>

# Optional future services
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=


